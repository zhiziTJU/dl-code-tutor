{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "target": "ES2020",
    "module": "CommonJS",
    "moduleResolution": "node",
    "outDir": "./dist/preload",
    "rootDir": "./src/preload",
    "noEmit": false,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "lib": ["ES2020"],
    "types": ["node"]
  },
  "include": ["src/preload/**/*"],
  "exclude": ["node_modules", "src/main", "src/renderer"]
}
